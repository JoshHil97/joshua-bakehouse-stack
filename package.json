{
  "name": "joshua-hilarion-bakehouse",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "bakehouse-app": "bin/bakehouse-app.js"
  },
  "scripts": {
    "build": "echo \"The build step is not required when using JavaScript!\" && exit 0",
    "cdk": "cdk",
    "synth": "cdk synth",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "npm test -- --runInBand",
    "test:ci": "npm run test:unit && npm --prefix client run lint && npm --prefix client run build && npm --prefix client run test:e2e",
    "test:load": "k6 run tests/load/products.k6.js"
  },
  "devDependencies": {
    "aws-cdk": "^2.1033.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.991.0",
    "@aws-sdk/client-rds-data": "^3.975.0",
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/lib-dynamodb": "^3.991.0",
    "aws-cdk-lib": "^2.215.0",
    "constructs": "^10.0.0",
    "data-api-client": "^2.1.3",
    "pdf-lib": "^1.17.1"
  }
}
